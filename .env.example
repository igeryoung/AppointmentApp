# Database Configuration
# Copy this file to .env and update with your actual values
# NEVER commit the .env file to git

# Supabase standard client variables (URL + KEY)
SUPABASE_URL=
# Backend only: use service_role/secret key, never expose to frontend.
SUPABASE_KEY=
# Optional client-side pool tuning for SDK adapters
SUPABASE_MAX_CONNECTIONS=10

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8443  # HTTPS port (use 8080 for HTTP in development only)

# SSL/TLS Configuration
# Development: Self-signed certificates (auto-generated in server/certs/)
# Production: Use Let's Encrypt or commercial certificates
ENABLE_SSL=true  # Set to false only for local HTTP development
SSL_CERT_PATH=certs/cert.pem  # Path to SSL certificate
SSL_KEY_PATH=certs/key.pem    # Path to SSL private key

# Production SSL Example (uncomment and configure for production):
# ENABLE_SSL=true
# SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem
# SERVER_PORT=443

# Development HTTP-only mode (INSECURE - for local testing only):
# ENABLE_SSL=false
# SERVER_PORT=8080
